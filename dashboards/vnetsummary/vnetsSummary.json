        "query": "resources\r\n| where type =~ 'microsoft.network/virtualnetworks'\r\n| mv-expand subnets = properties.subnets\r\n| project\r\n    VNetName = name,\r\n    VNetId = id,\r\n    //SubnetName = tostring(subnets.name),\r\n    Subnet = tostring(subnets.id),\r\n    AddressPrefix = tostring(subnets.properties.addressPrefix),\r\n    NSGId = tostring(subnets.properties.networkSecurityGroup.id),\r\n    UDRId = tostring(subnets.properties.routeTable.id)\r\n| order by VNetName asc\r\n",
