    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 9,
            "content": {
              "version": "KqlParameterItem/1.0",
              "parameters": [
                {
                  "id": "735dde81-9396-41ba-9f50-8b910bb7bf00",
                  "version": "KqlParameterItem/1.0",
                  "name": "FlowType2",
                  "label": "FlowType",
                  "type": 2,
                  "typeSettings": {
                    "additionalResourceOptions": [],
                    "showDefault": false
                  },
                  "jsonData": "[{ \"value\": \"'External'\", \"label\": \"External\" },{ \"value\": \"'Internal'\", \"label\": \"Internal\"}, { \"value\": \"'Internal','External'\", \"label\": \"Both\", \"selected\":true }]",
                  "value": "'External'"
                }
              ],
              "style": "pills",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces"
            },
            "name": "parameters - general"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "NTANetAnalytics\r\n| where SubType == \"FlowLog\"\r\n| extend FlowType2 = iff((isnotempty(SrcPublicIps) or isnotempty(DestPublicIps)), \"External\", \"Internal\")\r\n| where FlowType2 in~ ({FlowType2})\r\n| extend azsrcpublicip = split(SrcPublicIps, \"|\")[0], azdestpublicip = split(DestPublicIps, \"|\")[0]\r\n| extend SrcIp = iff(isempty(SrcIp), azsrcpublicip, SrcIp), DestIp = iff(isempty(DestIp), azdestpublicip, DestIp)\r\n| summarize\r\n    bytes_in  = sum(coalesce(BytesDestToSrc, 0)),\r\n    bytes_out = sum(coalesce(BytesSrcToDest, 0)),\r\n    total= sum(coalesce(BytesDestToSrc, 0))+sum(coalesce(BytesSrcToDest, 0))\r\nby SrcIp\r\n| sort by total desc \r\n| project-away total\r\n| take 15",
              "size": 0,
              "title": "Source Total bytes",
              "noDataMessage": "No flows found",
              "timeContextFromParameter": "Time",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "crossComponentResources": [
                "{LAW}"
              ],
              "visualization": "categoricalbar",
              "chartSettings": {
                "showLegend": true
              }
            },
            "name": "query - Source Flow"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "NTANetAnalytics\r\n| where SubType == \"FlowLog\"\r\n| extend FlowType2 = iff((isnotempty(SrcPublicIps) or isnotempty(DestPublicIps)), \"External\", \"Internal\")\r\n| where FlowType2 in~ ({FlowType2})\r\n| extend azsrcpublicip = split(SrcPublicIps, \"|\")[0], azdestpublicip = split(DestPublicIps, \"|\")[0]\r\n| extend SrcIp = iff(isempty(SrcIp), azsrcpublicip, SrcIp), DestIp = iff(isempty(DestIp), azdestpublicip, DestIp)\r\n| summarize\r\n    bytes_in  = sum(coalesce(BytesDestToSrc, 0)),\r\n    bytes_out = sum(coalesce(BytesSrcToDest, 0))\r\nby DestIp\r\n| take 15",
              "size": 0,
              "title": "Destination Total bytes",
              "noDataMessage": "No flows found",
              "timeContextFromParameter": "Time",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "crossComponentResources": [
                "{LAW}"
              ],
              "visualization": "categoricalbar"
            },
            "name": "query - Destination Flow"
          }
        ]
