          {
            "type": 9,
            "content": {
              "version": "KqlParameterItem/1.0",
              "parameters": [
                {
                  "id": "cd1efe58-b07e-4f01-9a13-de7c263fe0b9",
                  "version": "KqlParameterItem/1.0",
                  "name": "VirtualNetworks",
                  "label": "Virtual Networks",
                  "type": 5,
                  "query": "resources\r\n| where type =~ 'microsoft.network/virtualnetworks'\r\n| project value=id, label=id",
                  "crossComponentResources": [
                    "value::tenant"
                  ],
                  "typeSettings": {
                    "additionalResourceOptions": []
                  },
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resources/tenants",
                  "value": "/subscriptions/e315fe54-eae5-464d-8266-0f41a0908da8/resourceGroups/rg-Hub/providers/Microsoft.Network/virtualNetworks/vnet-hub"
                },
                {
                  "id": "3c89e878-0248-470c-8762-43381088370f",
                  "version": "KqlParameterItem/1.0",
                  "name": "FlowType3",
                  "label": "Flow Type",
                  "type": 2,
                  "typeSettings": {
                    "additionalResourceOptions": [],
                    "showDefault": false
                  },
                  "jsonData": "[{ \"value\": \"'External'\", \"label\": \"External\" },{ \"value\": \"'Internal'\", \"label\": \"Internal\"}, { \"value\": \"'Internal','External'\", \"label\": \"Both\", \"selected\":true }]"
                },
                {
                  "id": "cb894c1d-0d18-4928-bc6e-d127fe4b0f47",
                  "version": "KqlParameterItem/1.0",
                  "name": "Window2",
                  "label": "Window",
                  "type": 2,
                  "typeSettings": {
                    "additionalResourceOptions": [],
                    "showDefault": false
                  },
                  "jsonData": "[{ \"value\": \"10\", \"label\": \"10m\", \"selected\":true  }\r\n, { \"value\": \"60\", \"label\": \"1h\"}]"
                }
              ],
              "style": "pills",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces"
            },
            "name": "parameters - 1"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "\r\nlet window = 10m;\r\nlet seconds = 10 * 60;\r\nNTANetAnalytics\r\n| where SubType == \"FlowLog\"and FaSchemaVersion == '3' and FlowType != 'IntraVnet'\r\n| extend FlowType3=iff((isnotempty(SrcPublicIps) or isnotempty(DestPublicIps)),\"External\", \"Internal\")\r\n| where FlowType3 in~ ({FlowType3})\r\n| extend vnetidsplit=split('{VirtualNetworks}','/')\r\n| where TargetResourceType == \"VirtualNetwork\" and TargetResourceId =~  strcat(vnetidsplit[2],'/',vnetidsplit[4],'/',vnetidsplit[8])\r\n| summarize\r\n    bytes_in = sumif(coalesce(BytesDestToSrc, 0), FlowDirection == \"Inbound\"),\r\n    bytes_out = sumif(coalesce(BytesSrcToDest, 0), FlowDirection == \"Outbound\")\r\n    by bin(FlowIntervalStartTime, window), SrcIp, DestIp, DestPort, L4Protocol\r\n| summarize\r\n    total_bytes_in = sum(bytes_in),\r\n    total_bytes_out = sum(bytes_out)\r\n    by FlowIntervalStartTime\r\n| extend bps_in = 8.0 * total_bytes_in / seconds,\r\n         bps_out = 8.0 * total_bytes_out / seconds\r\n| project FlowIntervalStartTime, bps_in, bps_out\r\n| render timechart\r\n",
              "size": 0,
              "title": "VNet Flow - bits",
              "timeContextFromParameter": "Time",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "crossComponentResources": [
                "{LAW}"
              ],
              "chartSettings": {
                "yAxis": [
                  "bps_in",
                  "bps_out"
                ]
              }
            },
            "name": "query - 0"
          }
        ]
      },
      "conditionalVisibility": {
